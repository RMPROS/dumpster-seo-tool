{
  "version": 2,
  "framework": "nextjs",
  "functions": {
    "pages/api/research.ts": {
      "maxDuration": 30
    },
    "pages/api/generate-excel.ts": {
      "maxDuration": 30
    }
  },
  "headers": [
    {
      "source": "/api/(.*)",
